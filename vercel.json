{
  "version": 2,
  "framework": null,
  "outputDirectory": ".",
  "builds": [
    {
      "src": "api/index.php",
      "use": "vercel-php@0.7.3"
    }
  ],
  "routes": [
    {
      "src": "/(build|assets|css|js|images|storage)/(.*)",
      "dest": "/public/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}